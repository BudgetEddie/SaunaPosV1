generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
}

enum LockerStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum PaymentMethod {
  CASH
  CARD
  GIFT_CARD
  VISIT_PASS
}

enum OrderStatus {
  QUEUED
  IN_PROGRESS
  READY
  COMPLETE
}

model Settings {
  id      Int   @id @default(1)
  taxRate Float @default(0.13)
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  isKitchen Boolean    @default(false)
  items     MenuItem[]
}

model MenuItem {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  name        String
  price       Float
  description String?
}

model Customer {
  id          Int       @id @default(autoincrement())
  firstName   String
  lastName    String
  gender      Gender
  phone       String?
  email       String?
  dateOfBirth DateTime?
  address     String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  visits      Visit[]
}

model Locker {
  id     Int          @id @default(autoincrement())
  number String
  gender Gender
  status LockerStatus @default(AVAILABLE)
  visits Visit[]
}

model Visit {
  id         Int       @id @default(autoincrement())
  customerId Int
  customer   Customer  @relation(fields: [customerId], references: [id])
  lockerId   Int
  locker     Locker    @relation(fields: [lockerId], references: [id])
  checkInAt  DateTime  @default(now())
  checkOutAt DateTime?
  bill       Bill?
  orders     Order[]
}

model Order {
  id        Int         @id @default(autoincrement())
  visitId   Int
  visit     Visit       @relation(fields: [visitId], references: [id])
  status    OrderStatus @default(QUEUED)
  createdAt DateTime    @default(now())
  items     OrderItem[]
}

model OrderItem {
  id      Int    @id @default(autoincrement())
  orderId Int
  order   Order  @relation(fields: [orderId], references: [id])
  name    String
}

model Bill {
  id            Int             @id @default(autoincrement())
  visitId       Int             @unique
  visit         Visit           @relation(fields: [visitId], references: [id])
  lineItems     BillLineItem[]
  taxRate       Float           @default(0.13)
  paymentMethod PaymentMethod?
  paidAt        DateTime?
  createdAt     DateTime        @default(now())
}

model BillLineItem {
  id          Int      @id @default(autoincrement())
  billId      Int
  bill        Bill     @relation(fields: [billId], references: [id])
  description String
  amount      Float
  createdAt   DateTime @default(now())
}